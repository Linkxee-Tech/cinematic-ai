# ── Backblaze B2 ──────────────────────────────────────────────────────────────
B2_KEY_ID=your_b2_key_id_here
B2_APP_KEY=your_b2_application_key_here
B2_BUCKET_NAME=cinematic-ai-assets

# ── GMI Cloud / Genblaze ──────────────────────────────────────────────────────
GMI_API_KEY=your_gmi_api_key_here

# ── Replicate ─────────────────────────────────────────────────────────────────
REPLICATE_API_TOKEN=your_replicate_token_here

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── ElevenLabs ────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/cinematic_ai

# ── Redis (Celery broker + backend) ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change_me_to_a_long_random_string_in_production

# ── App settings ─────────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
